{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/azure-devops/:key/:path*", "destination": "/api/azure-devops/[...path]" },
    { "source": "/api/jira/:path*",              "destination": "/api/jira/[...path]" },
    { "source": "/(.*)",                         "destination": "/index.html" }
  ]
}
